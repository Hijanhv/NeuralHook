# ── Unichain Sepolia RPC ──────────────────────────────────────────────────────
RPC_URL=https://unichain-sepolia-rpc.publicnode.com
CHAIN_ID=1301

# ── Wallets ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...           # wallet that submits on-chain txs (needs Unichain Sepolia ETH)
ORACLE_PRIVATE_KEY=0x...    # signs inference results — can be same as PRIVATE_KEY for testing

# ── Deployed contract addresses ───────────────────────────────────────────────
HOOK_ADDRESS=0x6DCb771F0A8A61F2679989453af9549C9ceA89c0
FUND_ADDRESS=0x4D575ac6C3df76C7E22EB59715F0a9e839f16811

# ── 0G Compute Network (AI inference) ────────────────────────────────────────
# Leave empty to use the local heuristic fallback (works without 0G credentials)
OG_PROVIDER_ADDRESS=
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# ── Uniswap Trading API (rebalance quotes + on-chain swap execution) ─────────
# Required for swap execution. Get a key at https://hub.uniswap.org
UNISWAP_API_KEY=
# Chain where the agent executes the rebalance swap (default: Base mainnet)
SWAP_CHAIN_ID=8453
SWAP_RPC_URL=https://mainnet.base.org
# Amount to swap on each CRITICAL event (in wei). Default: 0.0001 ETH
SWAP_AMOUNT_WEI=100000000000000

# ── MCP server port ───────────────────────────────────────────────────────────
MCP_PORT=5000
