# Unichain Sepolia RPC
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
RPC_URL=https://sepolia.unichain.org

# Deployer / oracle wallet
PRIVATE_KEY=0x...
ORACLE_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...
ORACLE_ADDRESS=0x...

# Deployed contract addresses (set after deploy)
HOOK_ADDRESS=0x...
FUND_ADDRESS=0x...
CHAIN_ID=1301

# Frontend contract addresses (copied from above after deploy)
NEXT_PUBLIC_HOOK_ADDRESS=0x...
NEXT_PUBLIC_FUND_ADDRESS=0x...

# Optional: 0G Inference endpoint
OG_ENDPOINT=

# WalletConnect project ID
NEXT_PUBLIC_WC_PROJECT_ID=demo
NEXT_PUBLIC_AGENT_0=http://localhost:4000
NEXT_PUBLIC_AGENT_1=http://localhost:4001
NEXT_PUBLIC_AGENT_2=http://localhost:4002
