# ── Unichain Sepolia RPC ──────────────────────────────────────────────────────
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
RPC_URL=https://sepolia.unichain.org
# USDC on Unichain Sepolia: 0x31d0220469e10c4E71834a79b1f276d740d3768F
# (NOT 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238 — that's Ethereum Sepolia USDC)

# ── Deployer / oracle wallets ─────────────────────────────────────────────────
PRIVATE_KEY=0x...                  # wallet that submits on-chain txs (needs ETH)
ORACLE_PRIVATE_KEY=0x...           # oracle signer — signs inference results
DEPLOYER_ADDRESS=0x...
ORACLE_ADDRESS=0x...

# ── Deployed contract addresses (fill after: forge script Deploy.s.sol) ───────
HOOK_ADDRESS=0x...
FUND_ADDRESS=0x...
CHAIN_ID=1301

# ── Frontend (Next.js) env vars ───────────────────────────────────────────────
NEXT_PUBLIC_HOOK_ADDRESS=0x...
NEXT_PUBLIC_FUND_ADDRESS=0x...
NEXT_PUBLIC_WC_PROJECT_ID=demo     # get a real ID at cloud.walletconnect.com
NEXT_PUBLIC_AGENT_0=http://localhost:4000
NEXT_PUBLIC_AGENT_1=http://localhost:4001
NEXT_PUBLIC_AGENT_2=http://localhost:4002

# ── 0G Compute Network (AI inference) ────────────────────────────────────────
# OG_PROVIDER_ADDRESS: on-chain address of a 0G inference provider you've
# subscribed to.  Testnet provider: 0x69Eb5a0BD7d0f4bF39eD5CE9Bd3376c61863aE08
# Leave empty to use the local heuristic fallback.
OG_PROVIDER_ADDRESS=
OG_PRIVATE_KEY=0x...               # wallet holding 0G tokens for inference billing
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# ── Gensyn AXL p2p gossip ─────────────────────────────────────────────────────
# Run the AXL binary first: https://github.com/gensyn-ai/axl
# Leave AXL_URL empty to fall back to HTTP gossip between agent processes.
AXL_URL=http://localhost:9002      # AXL binary JSON-RPC endpoint
AXL_KEY_PATH=./keys/node.pem      # ed25519 private key PEM (one per agent node)

# ── KeeperHub MCP server ──────────────────────────────────────────────────────
# Port the NeuralHook MCP server listens on.
# Run: cd agents && npm run mcp
MCP_PORT=5000

# ── Agent ports (when running agents manually) ────────────────────────────────
# NODE_ID=0
# PORT=4000
